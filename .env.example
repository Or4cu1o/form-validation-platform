# ---------------------------------------------------------------------------
# FormOps — Variáveis de ambiente (copie para .env e preencha os valores reais)
# ---------------------------------------------------------------------------

# --- PostgreSQL ---
POSTGRES_USER=formops
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=formops
POSTGRES_PORT=5432
DATABASE_URL=postgresql://formops:change-me-to-a-strong-password@localhost:5432/formops

# --- Object Storage (MinIO em dev / S3 em prod) ---
MINIO_ROOT_USER=formops
MINIO_ROOT_PASSWORD=change-me-to-a-strong-password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=formops-evidencias
S3_ACCESS_KEY=formops
S3_SECRET_KEY=change-me-to-a-strong-password
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# --- Autenticacao ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h

# --- Admin inicial (provisionado no primeiro start em producao) ---
INITIAL_ADMIN_MATRICULA=00001
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-me-to-a-strong-password

# --- E-mail transacional ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="FormOps <no-reply@example.com>"

# --- Portas da aplicacao ---
WEB_PORT=7443
API_PORT=7444
VITE_API_URL=http://localhost:7444

# --- Seeds de desenvolvimento ---
NODE_ENV=development
SEED_ON_START=true
SEED_PROPRIETARY_FORMS=false
