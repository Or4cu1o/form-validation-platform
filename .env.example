# ---------------------------------------------------------------------------
# RTIO — Variaveis de ambiente (copie para .env e preencha os valores reais)
# ---------------------------------------------------------------------------

# --- PostgreSQL ---
POSTGRES_USER=rtio
POSTGRES_PASSWORD=change-me
POSTGRES_DB=rtio
POSTGRES_PORT=5432
# Usada pela API (Prisma). Em docker-compose o host "postgres" ja resolve;
# fora do compose, aponte para o host real do banco.
DATABASE_URL=postgresql://rtio:change-me@postgres:5432/rtio

# --- Object Storage (MinIO em dev / S3 ou Azure Blob compat. em prod) ---
MINIO_ROOT_USER=rtio
MINIO_ROOT_PASSWORD=change-me
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=rtio-evidencias
S3_ACCESS_KEY=rtio
S3_SECRET_KEY=change-me
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# --- Autenticacao ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h

# --- Admin inicial (provisionado no primeiro start em producao) ---
INITIAL_ADMIN_MATRICULA=00001
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-me

# --- E-mail transacional (SMTP direto, ex.: Microsoft 365 / smtp.office365.com) ---
# Se SMTP_HOST ficar vazio, o EmailService cai em modo log/console (dev).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="RTIO <no-reply@example.com>"

# --- Portas da aplicacao ---
API_PORT=7000
WEB_PORT=7173
VITE_API_URL=http://localhost:7000

# --- Seeds de desenvolvimento ---
NODE_ENV=development
SEED_ON_START=true
SEED_PROPRIETARY_FORMS=false
